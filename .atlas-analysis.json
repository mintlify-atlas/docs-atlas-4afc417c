  "keyFeatures": [
    "Full support for Epic Games friends system with XMPP events",
    "Comprehensive party management and invitations",
    "Battle Royale stats and competitive rank tracking",
    "Multiple authentication methods including device auth",
    "Commands framework extension similar to discord.py",
    "Async/await support with aiohttp",
    "Friend and party messaging capabilities",
    "Creative islands, store items, and news integration"
